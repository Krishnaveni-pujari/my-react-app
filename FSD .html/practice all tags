<!DOCTYPE html>
<html>
<head>
    <title>HTML Tags Example</title>
</head>

<body>

<header>
    <h1>Welcome to My Web Page</h1>
    <p>This page shows <strong>HTML tags</strong> with examples.</p>
</header>

<hr>

<nav>
    <a href="#">Home</a> |
    <a href="#">About</a> |
    <a href="#">Contact</a>
</nav>

<section>
    <h2>Text Formatting</h2>
    <p>This is <b>bold</b>, <i>italic</i>, <u>underlined</u> text.</p>
    <p>This is <em>emphasized</em> text.</p>
</section>

<section>
    <h2>Image</h2>
    <img src="https://via.placeholder.com/150" alt="Sample Image">
</section>

<section>
    <h2>Lists</h2>
    <h3>Unordered List</h3>
    <ul>
        <li>HTML</li>
        <li>CSS</li>
        <li>JavaScript</li>
    </ul>

    <h3>Ordered List</h3>
    <ol>
        <li>Design</li>
        <li>Develop</li>
        <li>Deploy</li>
    </ol>
</section>

<section>
    <h2>Table</h2>
    <table border="1">
        <tr>
            <th>Name</th>
            <th>Course</th>
        </tr>
        <tr>
            <td>Asha</td>
            <td>HTML</td>
        </tr>
        <tr>
            <td>Ravi</td>
            <td>CSS</td>
        </tr>
    </table>
</section>

<section>
    <h2>Form</h2>
    <form>
        <label>Name:</label>
        <input type="text"><br><br>

        <label>Message:</label><br>
        <textarea rows="3" cols="20"></textarea><br><br>

        <label>Course:</label>
        <select>
            <option>HTML</option>
            <option>CSS</option>
        </select><br><br>

        <button type="submit">Submit</button>
    </form>
</section>

<footer>
    <p>© 2026 My Website</p>
</footer>

</body>
</html>
